{
    "name": "haspadar/piqule",
    "description": "Static analysis and linters for PHP projects",
    "type": "library",
    "license": "MIT",
    "bin": [
        "bin/piqule-sync",
        "bin/piqule"
    ],
    "autoload": {
        "psr-4": {
            "Haspadar\\Piqule\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Haspadar\\Piqule\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Kanstantsinas Mesnikas",
            "email": "haspadar@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
      "php": ">=8.3"
    }
}
