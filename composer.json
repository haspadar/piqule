{
    "name": "haspadar/piqule",
    "description": "Quality checks for PHP projects",
    "type": "library",
    "license": "MIT",
    "bin": [
        "bin/piqule"
    ],
    "autoload": {
        "psr-4": {
            "Haspadar\\Piqule\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Haspadar\\Piqule\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Kanstantsinas Mesnikas",
            "email": "haspadar@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "~8.3.16 || ~8.4.3 || ~8.5.0",
        "friendsofphp/php-cs-fixer": "^3.91",
        "infection/infection": "^0.32.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpmd/phpmd": "^2.15",
        "phpmetrics/phpmetrics": "^2.9",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0",
        "symfony/process": "^8.0",
        "vimeo/psalm": "^6.14"
    },
    "suggest": {
        "ext-xdebug": "Required to generate coverage reports and run Infection"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        },
        "sort-packages": true
    },
    "prefer-stable": true
}
