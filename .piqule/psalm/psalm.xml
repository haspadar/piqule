<?xml version="1.0"?>
<psalm
        errorLevel="1"
        xmlns="https://getpsalm.org/schema/config"
        findUnusedCode="false"
>
    <projectFiles>
        <directory name="../../src" />
        <ignoreFiles>
            <directory name="../../vendor" />
            <directory name="../../tests" />
            <directory name="../../.git" />
        </ignoreFiles>
    </projectFiles>
    <issueHandlers>
        <InvalidAttribute errorLevel="suppress" />
    </issueHandlers>
</psalm>
