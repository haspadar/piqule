{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": ["config:recommended"],

  "schedule": ["* 1-4 * * *"],
  "timezone": "UTC",

  "labels": ["dependencies"],

  "prConcurrentLimit": 3,
  "prHourlyLimit": 0,

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },

  "composer": {
    "enabled": true
  },

  "github-actions": {
    "enabled": true
  },

  "dockerfile": {
    "enabled": true
  },

  "packageRules": [
    {
      "description": "Update pinned GitHub Actions SHAs",
      "matchManagers": ["github-actions"],
      "updatePinnedDependencies": true
    },
    {
      "description": "Automerge safe updates",
      "matchDatasources": ["github-releases", "packagist", "npm", "docker"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Mark major updates as breaking",
      "matchUpdateTypes": ["major"],
      "labels": ["breaking"]
    },
    {
      "description": "Group CI and toolchain updates",
      "groupName": "CI and toolchain",
      "matchManagers": ["github-actions", "dockerfile", "regex"]
    }
  ],

  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG ACTIONLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "rhysd/actionlint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG HADOLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "hadolint/hadolint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG TYPOS_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "crate-ci/typos",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG SHELLCHECK_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "koalaman/shellcheck",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG MARKDOWNLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "markdownlint-cli2",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG JSONLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "@prantlf/jsonlint",
      "datasourceTemplate": "npm"
    },

    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPSTAN_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpstan/phpstan",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PSALM_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "vimeo/psalm",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPUNIT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpunit/phpunit",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG INFECTION_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "infection/infection",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPMD_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpmd/phpmd",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPMETRICS_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpmetrics/phpmetrics",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPCS_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpcsstandards/php_codesniffer",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPCSFIXER_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "friendsofphp/php-cs-fixer",
      "datasourceTemplate": "packagist"
    }
  ]
}
