{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": ["config:recommended"],

  "schedule": ["* 1-4 * * *"],
  "timezone": "UTC",

  "labels": ["dependencies"],

  "prConcurrentLimit": 3,
  "prHourlyLimit": 0,

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },

  "composer": { "enabled": false },
  "github-actions": { "enabled": true },
  "dockerfile": { "enabled": false },

  "packageRules": [
    {
      "description": "Pin GitHub Actions to commit SHA",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Group CI and toolchain updates",
      "groupName": "CI and toolchain",
      "matchManagers": ["github-actions", "regex"]
    }
  ],

  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHP_IMAGE=php:(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "php",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG NODE_IMAGE=node:(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },

    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG ACTIONLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "rhysd/actionlint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG HADOLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "hadolint/hadolint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG TYPOS_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "crate-ci/typos",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG SHELLCHECK_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "koalaman/shellcheck",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG MARKDOWNLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "markdownlint-cli2",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG YAMLLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "yamllint",
      "datasourceTemplate": "pypi"
    },

    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPSTAN_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpstan/phpstan",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PSALM_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "vimeo/psalm",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPUNIT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpunit/phpunit",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG INFECTION_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "infection/infection",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPMD_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpmd/phpmd",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPMETRICS_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpmetrics/phpmetrics",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPCS_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "phpcsstandards/php_codesniffer",
      "datasourceTemplate": "packagist"
    },
    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG PHPCSFIXER_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "friendsofphp/php-cs-fixer",
      "datasourceTemplate": "packagist"
    },

    {
      "customType": "regex",
      "fileMatch": ["docker/Dockerfile$"],
      "matchStrings": [
        "ARG JSONLINT_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "@prantlf/jsonlint",
      "datasourceTemplate": "npm"
    }
  ]
}
