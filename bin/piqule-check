#!/usr/bin/env php
<?php

declare(strict_types=1);

use Haspadar\Piqule\Config\DefaultConfig;
use Haspadar\Piqule\Config\OverrideConfig;

require_once __DIR__ . '/../vendor/autoload.php';

$projectRoot = getcwd() ?: throw new RuntimeException('Cannot determine cwd');

$config = file_exists($projectRoot . '/.piqule.php')
    ? require $projectRoot . '/.piqule.php'
    : new OverrideConfig(new DefaultConfig(), []);

$requested = $argv[1] ?? '';

$checks = [
    'actionlint',
    'hadolint',
    'markdownlint',
    'yamllint',
    'typos',
    'shellcheck',
    'jsonlint',
    'phpstan',
    'psalm',
    'phpmd',
    'phpmetrics',
    'phpcs',
    'php-cs-fixer',
    'phpunit',
    'infection',
];

$titleWidth = 18;
$total = $requested !== '' ? 1 : count($checks);
$current = 0;

$green = fn(string $s) => "\033[32m{$s}\033[0m\n";
$blue  = fn(string $s) => "\033[34m{$s}\033[0m\n";
$red   = fn(string $s) => "\033[31m{$s}\033[0m\n";

$runCheck = function(string $key) use ($projectRoot, $config, $green, $blue, $red, $total, &$current, $titleWidth): bool {
    $command = "{$projectRoot}/.piqule/{$key}/command.sh";

    if (!file_exists($command)) {
        echo ($red)("Unknown check: {$key}");
        return false;
    }

    $enabledKey = "{$key}.enabled";
    $enabled = $config->has($enabledKey)
        ? (bool) ($config->list($enabledKey)[0] ?? true)
        : true;

    if (!$enabled) {
        echo ($blue)("[SKIP] {$key}");
        return true;
    }

    $current++;

    if ($total > 1) {
        echo ($blue)(sprintf('[RUN]  %-' . $titleWidth . 's (%d/%d)', $key, $current, $total));
    } else {
        echo ($blue)("[RUN]  {$key}");
    }

    passthru("bash {$command}", $status);

    if ($status !== 0) {
        echo ($red)("[FAIL] {$key}");
        return false;
    }

    echo ($green)("[OK]   {$key}");
    echo "\n";
    return true;
};

if ($requested !== '') {
    exit($runCheck($requested) ? 0 : 1);
}

foreach ($checks as $key) {
    if (!$runCheck($key)) {
        exit(1);
    }
}

echo ($green)('All checks passed');
