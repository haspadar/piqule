#!/usr/bin/env php
<?php

declare(strict_types=1);

use Haspadar\Piqule\Config\Config;
use Haspadar\Piqule\Config\DefaultConfig;
use Haspadar\Piqule\Config\OverrideConfig;

require_once __DIR__ . '/bootstrap-autoload.php';

$projectRoot = getcwd() ?: throw new RuntimeException('Cannot determine cwd');

if (file_exists($projectRoot . '/.piqule.php')) {
    $loaded = require $projectRoot . '/.piqule.php';
    if (!$loaded instanceof Config) {
        fwrite(STDERR, ".piqule.php must return an instance of Config\n");
        exit(1);
    }
    $config = $loaded;
} else {
    $config = new OverrideConfig(new DefaultConfig(), []);
}

$requested = $argv[1] ?? '';

$checks = [
    'actionlint',
    'hadolint',
    'markdownlint',
    'yamllint',
    'typos',
    'shellcheck',
    'jsonlint',
    'phpstan',
    'psalm',
    'phpmd',
    'phpmetrics',
    'phpcs',
    'php-cs-fixer',
    'phpunit',
    'infection',
    'sonar',
];

$isEnabled = function(string $key) use ($config): bool {
    $enabledKey = "{$key}.enabled";
    return !$config->has($enabledKey) || (bool)($config->list($enabledKey)[0] ?? true);
};

$total = $requested !== '' ? 1 : count(array_filter($checks, $isEnabled));
$current = 0;

$green = fn(string $s) => "\033[32m{$s}\033[0m\n";
$blue  = fn(string $s) => "\033[34m{$s}\033[0m\n";
$red   = fn(string $s) => "\033[31m{$s}\033[0m\n";

$runCheck = function(string $key) use ($projectRoot, $isEnabled, $green, $blue, $red, $total, &$current,): bool {
    $command = "{$projectRoot}/.piqule/{$key}/command.sh";

    if (!file_exists($command)) {
        echo ($red)("Unknown check: {$key}");
        return false;
    }

    if (!$isEnabled($key)) {
        echo ($blue)("[SKIP] {$key}");
        return true;
    }

    $current++;

    $titleWidth = 18;
    if ($total > 1) {
        echo ($blue)(sprintf('[RUN]  %-' . $titleWidth . 's (%d/%d)', $key, $current, $total));
    } else {
        echo ($blue)("[RUN]  {$key}");
    }

    passthru('bash ' . escapeshellarg($command), $status);

    if ($status !== 0) {
        echo ($red)("[FAIL] {$key}");
        return false;
    }

    echo ($green)("[OK]   {$key}");
    echo "\n";
    return true;
};

if ($requested !== '') {
    exit($runCheck($requested) ? 0 : 1);
}

foreach ($checks as $key) {
    if (!$runCheck($key)) {
        exit(1);
    }
}

echo ($green)('All checks passed');
