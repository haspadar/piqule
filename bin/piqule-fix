#!/usr/bin/env bash
set -euo pipefail

# Psalm auto-fix
vendor/bin/psalm \
  --config=.piqule/psalm/psalm.xml \
  --no-cache \
  --alter \
  --issues=MissingOverrideAttribute

# PHPCBF (code sniffer fixer)
vendor/bin/phpcbf \
  --standard=.piqule/phpcs/phpcs.xml

# PHP CS Fixer
vendor/bin/php-cs-fixer fix \
  --config=.piqule/php-cs-fixer/php-cs-fixer.project.php