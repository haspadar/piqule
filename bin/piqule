#!/usr/bin/env bash
set -euo pipefail

# ------------------------------------------------------------
# Ensure we are in project root
# ------------------------------------------------------------
ensure_project_root() {
  if [ ! -d ".piqule" ]; then
    echo "Error: run piqule from project root ('.piqule' directory not found)"
    exit 1
  fi
}

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  sync)
    "$(dirname "$0")/piqule-sync" "$@"
    "$(dirname "$0")/piqule-pin"
    "$(dirname "$0")/piqule-tokens-check"
    ;;
  check|fix)
    ensure_project_root
    "$(dirname "$0")/piqule-verify"
    "$(dirname "$0")/piqule-${COMMAND}" "$@"
    "$(dirname "$0")/piqule-tokens-check"
    ;;
  skill)
    "$(dirname "$0")/piqule-skill" "$@"
    ;;
  *)
    echo "Usage: piqule [sync|check|fix|skill]"
    exit 1
    ;;
esac
