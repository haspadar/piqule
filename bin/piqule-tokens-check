#!/usr/bin/env php
<?php

declare(strict_types=1);

use Haspadar\Piqule\Config\Config;
use Haspadar\Piqule\Config\ConfigPaths;
use Haspadar\Piqule\Config\DefaultConfig;
use Haspadar\Piqule\Config\YamlConfig;
use Haspadar\Piqule\EnvVar\EnvVars;
use Haspadar\Piqule\EnvVar\SonarEnvVar;
use Haspadar\Piqule\Output\Console;
use Haspadar\Piqule\Secret\CodecovSecret;
use Haspadar\Piqule\Secret\InfectionSecret;
use Haspadar\Piqule\Secret\Secrets;

require_once __DIR__ . '/bootstrap-autoload.php';

$output = new Console();

$projectRoot = getcwd() ?: throw new RuntimeException('Cannot determine cwd');
$yamlPath = $projectRoot . '/.piqule.yaml';

try {
    $defaults = new DefaultConfig(paths: new ConfigPaths($projectRoot . '/composer.json'));
} catch (Throwable $e) {
    $output->error("Failed to load default config: {$e->getMessage()}");
    exit(1);
}

if (file_exists($yamlPath)) {
    try {
        $config = new YamlConfig($yamlPath, $defaults);
    } catch (Throwable $e) {
        $output->error("Failed to load .piqule.yaml: {$e->getMessage()}");
        exit(1);
    }
} elseif (file_exists($projectRoot . '/.piqule.php')) {
    $loaded = require $projectRoot . '/.piqule.php';

    if (!$loaded instanceof Config) {
        $output->error('.piqule.php must return an instance of Config');
        exit(1);
    }

    $config = $loaded;
} else {
    $config = $defaults;
}

$envVars = new EnvVars([
    new SonarEnvVar(),
]);

$secrets = new Secrets([
    new CodecovSecret(),
    new InfectionSecret(),
]);

$enabledEnvVars = array_filter(
    $envVars->items(),
    fn($var) => $var->enabled($config),
);

foreach ($enabledEnvVars as $var) {
    $env = getenv($var->name());

    if ($env !== false && $env !== '') {
        continue;
    }

    $output->info(sprintf('[ENV] %s is missing. Get it at: %s', $var->name(), $var->url()));
    $output->info(sprintf('[ENV] export %s=<your-token>  (bash/zsh)', $var->name()));
    $output->info(sprintf('[ENV] set -Ux %s <your-token>  (fish)', $var->name()));
}

$enabledSecrets = array_filter(
    $secrets->items(),
    fn($secret) => $secret->enabled($config),
);

if ($enabledSecrets === []) {
    exit(0);
}

exec('command -v gh', $ghOut, $ghExists);

if ($ghExists !== 0) {
    $output->info('[SECRET] Install GitHub CLI to verify secrets: https://cli.github.com');
    exit(0);
}

exec('gh auth status 2>/dev/null', $authOut, $authStatus);

if ($authStatus !== 0) {
    $output->info('[SECRET] Run: gh auth login — to enable secret verification');
    exit(0);
}

exec('gh secret list --json name 2>/dev/null', $secretsJson, $secretsStatus);

if ($secretsStatus !== 0) {
    exit(0);
}

/** @var list<array{name: string}> $decoded */
$decoded = json_decode(implode('', $secretsJson), true) ?? [];
$existing = array_column($decoded, 'name');

$repoOut = [];
exec('gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null', $repoOut, $repoStatus);

$repoLines = array_values(array_filter($repoOut, 'is_string'));
$repo = $repoStatus === 0 && $repoLines !== [] ? trim($repoLines[0]) : '';
$org = $repo !== '' ? explode('/', $repo)[0] : '';

foreach ($enabledSecrets as $secret) {
    if (in_array($secret->name(), $existing, true)) {
        continue;
    }

    $output->info(sprintf('[SECRET] %s is missing. Get it at: %s', $secret->name(), $secret->url($org)));
    if ($repo !== '') {
        $output->info(sprintf('[SECRET] Add it at: https://github.com/%s/settings/secrets/actions/new', $repo));
    }
}
