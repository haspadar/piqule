#!/usr/bin/env bash
set -euo pipefail

LIBRARY_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TEMPLATES_DIR="${LIBRARY_ROOT}/templates"
PINNED=".piqule/templates.md5"

if [ ! -f "$PINNED" ]; then
  exit 0
fi

command -v md5sum &>/dev/null && MD5="md5sum" || MD5="md5 -r"

CURRENT="$(find "$TEMPLATES_DIR/always" "$TEMPLATES_DIR/git" -type f \
  | sort \
  | xargs "$MD5" \
  | "$MD5" \
  | awk '{print $1}')"

if [ "$CURRENT" != "$(cat "$PINNED")" ]; then
  echo -e "\033[31mTemplates have changed. Run: piqule sync\033[0m"
else
  echo -e "\033[32mTemplates are up to date\033[0m"
fi
