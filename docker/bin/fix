#!/usr/bin/env bash
set -euo pipefail

PROJECT=/project

psalm \
  --root="${PROJECT}" \
  --config="${PROJECT}/.piqule/psalm/psalm.xml" \
  --no-plugins \
  --no-cache \
  --alter \
  --issues=MissingOverrideAttribute

phpcbf \
  --standard="${PROJECT}/.piqule/phpcs/phpcs.xml" \
  "${PROJECT}"

php-cs-fixer fix \
  "${PROJECT}" \
  --config="${PROJECT}/.piqule/php-cs-fixer/php-cs-fixer.project.php"
