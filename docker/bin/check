#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# Environment
# ============================================================

PROJECT=/project

if [ ! -d "$PROJECT" ]; then
  echo "Project directory $PROJECT not found"
  exit 1
fi

cd "$PROJECT"

VENDOR_READY=false

ensure_vendor() {
  if [ ! -f composer.json ]; then
    return 0
  fi

  if [ "$VENDOR_READY" = true ]; then
    return 0
  fi

  if [ -f vendor/autoload.php ]; then
    VENDOR_READY=true
    return 0
  fi

  printf "\033[34m[RUN]  Composer install\033[0m\n"
  composer install --no-interaction --no-progress
  VENDOR_READY=true
}

TITLE_WIDTH=18
CURRENT=0
REQUESTED_KEY="${1:-}"

green() { printf "\033[32m%s\033[0m\n" "$1"; }

declare -a CHECK_TITLES=()
declare -a CHECK_KEYS=()
declare -a CHECK_CMDS=()

# ============================================================
# Check registration helper
# ============================================================

# Usage:
#   add_check "Title" key "command"
add_check() {
  CHECK_TITLES+=("$1")
  CHECK_KEYS+=("$2")
  CHECK_CMDS+=("$3")
}

# ============================================================
# Checks configuration
# ============================================================

add_check "Actionlint"   "actionlint"   "actionlint"
add_check "Hadolint"     "hadolint"     "bash .piqule/hadolint/args.sh | xargs -0 -r -n1 hadolint --config .piqule/hadolint/.hadolint.yml"
add_check "Markdown"     "markdownlint" "markdownlint-cli2 --config .piqule/markdownlint/.markdownlint-cli2.jsonc"
add_check "Yamllint"     "yamllint"     "yamllint -c .piqule/yamllint/.yamllint.yml ."
add_check "Typos"        "typos"        "typos --config .piqule/typos/_typos.toml"
add_check "ShellCheck"   "shellcheck"   "bash .piqule/shellcheck/args.sh | xargs -0 -r shellcheck --rcfile .piqule/shellcheck/.shellcheckrc"
add_check "JSONLint"     "jsonlint"     "jsonlint -f .piqule/jsonlint/config.json"
add_check "XML"          "xmllint"      "xmllint --noout .piqule/*/*.xml"
add_check "PHPCS"        "phpcs"        "phpcs --standard=.piqule/phpcs/phpcs.xml"
add_check "PHP CS Fixer" "php-cs-fixer" "php-cs-fixer fix --config=.piqule/php-cs-fixer/php-cs-fixer.project.php --dry-run --diff"
add_check "PHPStan"      "phpstan"      "phpstan analyse -c .piqule/phpstan/phpstan.neon --memory-limit=1G"
add_check "Psalm"        "psalm"        "psalm --root=. --config=.piqule/psalm/psalm.xml --no-cache"
add_check "PHPMD"        "phpmd"        "phpmd src text .piqule/phpmd/phpmd.xml"
# Use $(which phpmetrics) so we can pass custom PHP flags via php -d
add_check "PHPMetrics"   "phpmetrics"   "php -d error_reporting='E_ALL & ~E_DEPRECATED' \$(which phpmetrics) --config=.piqule/phpmetrics/phpmetrics.yml && php .piqule/phpmetrics/verify.php"
add_check "PHPUnit"      "phpunit"      "phpunit -c .piqule/phpunit/phpunit.xml --order-by=random"
add_check "Infection"    "infection"    "XDEBUG_MODE=coverage infection --configuration=.piqule/infection/infection.json5 --threads=max"

# ============================================================
# Compute total checks to execute
# ============================================================

TOTAL=0
for key in "${CHECK_KEYS[@]}"; do
  if [ -z "$REQUESTED_KEY" ] || [ "$REQUESTED_KEY" = "$key" ]; then
    TOTAL=$((TOTAL + 1))
  fi
done

# ============================================================
# Runner
# ============================================================

run_check() {
  local title="$1"
  local key="$2"
  local cmd="$3"

  CURRENT=$((CURRENT + 1))

  # ------------------------------------------------------------
  # Ensure project dependencies for checks that need autoload
  # ------------------------------------------------------------
  case "$key" in
    phpunit|infection|phpstan|psalm)
      ensure_vendor
      ;;
  esac

  if [ "$TOTAL" -gt 1 ]; then
    printf "\033[34m[RUN]  %-${TITLE_WIDTH}s (%d/%d)\033[0m\n" \
      "$title" "$CURRENT" "$TOTAL"
  else
    printf "\033[34m[RUN]  %s\033[0m\n" "$title"
  fi

  set +e
  bash -c "$cmd"
  local status=$?
  set -e

  if [ $status -ne 0 ]; then
    if [ "$TOTAL" -gt 1 ]; then
      printf "\033[31m[FAIL] %-${TITLE_WIDTH}s (%d/%d)\033[0m\n\n" \
        "$title" "$CURRENT" "$TOTAL"
    else
      printf "\033[31m[FAIL] %s\033[0m\n\n" "$title"
    fi
    exit $status
  fi

  if [ "$TOTAL" -gt 1 ]; then
    printf "\033[32m[OK]   %-${TITLE_WIDTH}s (%d/%d)\033[0m\n\n" \
      "$title" "$CURRENT" "$TOTAL"
  else
    printf "\033[32m[OK]   %s\033[0m\n\n" "$title"
  fi
}

# ============================================================
# Execution
# ============================================================

matched=false

for i in "${!CHECK_TITLES[@]}"; do
  title="${CHECK_TITLES[$i]}"
  key="${CHECK_KEYS[$i]}"
  cmd="${CHECK_CMDS[$i]}"

  if [ -n "$REQUESTED_KEY" ] && [ "$REQUESTED_KEY" != "$key" ]; then
    continue
  fi

  matched=true
  run_check "$title" "$key" "$cmd"
done

if [ -n "$REQUESTED_KEY" ] && [ "$matched" = false ]; then
  echo "Unknown check key: $REQUESTED_KEY"
  echo "Available keys:"
  for k in "${CHECK_KEYS[@]}"; do
    echo "  - $k"
  done
  exit 1
fi

green "All checks passed"
