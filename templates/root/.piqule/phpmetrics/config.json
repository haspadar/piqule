{
  "composer": false,
  "includes": [
<< config(phpmetrics.includes)
|default_list(["../../src"])
|format_each('    "%s"')
|join(",\n")
>>
  ],
  "excludes": [
<< config(phpmetrics.excludes)
|default_list(["vendor","tests","build","bin","var","node_modules"])
|format_each('    "%s"')
|join(",\n")
>>
  ],
  "extensions": [
<< config(phpmetrics.extensions)
|default_list(["php"])
|format_each('    "%s"')
|join(",\n")
>>
  ],
  "report": {
    "html": "<< config(phpmetrics.report.html)|default_list(["html"])|join("") >>",
    "json": "<< config(phpmetrics.report.json)|default_list(["phpmetrics.json"])|join("") >>"
  }
}